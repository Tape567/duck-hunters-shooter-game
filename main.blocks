ype="argument_reporter_string" id="ZpV~%c*zx9le4eMZWH9X"><mutation localizationname="miniMenu.onButtonPressed|handlerParam|selection"></mutation><field name="VALUE">selection</field></block></value><value name="B"><shadow type="text" id="/Dct%r9?AW^Vum!(igWv"><field name="TEXT">Credits</field></shadow></value></block></value><statement name="DO4"><block type="game_show_long_text" id="BpCUh0ydr]S.6=vmJYAT"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="@1?J)U8zUp78es3o5~u/"><field name="TEXT">All assets are made by RoboVacDev.</field></shadow></value><next><block type="game_show_long_text" id="/mkjh2Btd?xYE_8gh-i?"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="T_F;RLvt-~QF`HIwd3zx"><field name="TEXT">Intro Animation by Cheetor11.</field></shadow></value></block></next></block></statement><statement name="ELSE"><block type="game_show_long_text" id="?#M|p;.1~I6(Wz7nzqM{"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="m=7CO!^H2=]HO.{4g#^?"><field name="TEXT">Ducks are taking over the fields in this fast-paced scrolling shooter game!</field></shadow></value><next><block type="game_show_long_text" id="$3+f#(:o3P~Lqhd[wU]^"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="FHS)Xznp`Y#@Ho|u3MoZ"><field name="TEXT">Move up and down to move, and press A to shoot.</field></shadow></value><next><block type="game_show_long_text" id="NbPG(Eb:xWrr2L*BOCyr"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="+:Ua0Xr:I,kSTE+Aiif$"><field name="TEXT">Shoot the score boosters to get a quick, 5-sec score boost.</field></shadow></value><next><block type="game_show_long_text" id="SPRD_3QoK@dbMZ?he0uu"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="!t*2R?=dARd-2k`3~0z{"><field name="TEXT">Also, look out for shield powerups! Shoot those and gain a 10-sec shield boost!</field></shadow></value><next><block type="game_show_long_text" id="aUH6a(km$YsbdvcKZG_/"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="/KZVGlkE1?t6$]a|Mt[+"><field name="TEXT">Shoot the ducks or avoid them. Just don't let them touch YOU!</field></shadow></value><next><block type="game_show_long_text" id="XZ?`9rjF[*_9q!u82i$U"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="~k-.@/K;Gvjs1jVm82w/"><field name="TEXT">Things get harder on score 200. Let's hope the start was enough to get you ready!</field></shadow></value><next><block type="game_show_long_text" id="hU3:~un.,4u6gfJA!/iz"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="8oN8qt4fr5OQW?AWnjM_"><field name="TEXT">And that's all! Now you know how to play Duck Hunters. Get out there and hunt some ducks!</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></next></block></statement></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="colorPauseUntilFadeDone" id="H@Or%fd]wB+.8O@S+iy." disabled-reasons="pxt_automatic_disabled" x="18" y="1506"></block><block type="variables_get" id="[*n1`Fh.c%!E6iwuLjNX" disabled-reasons="pxt_automatic_disabled" x="1569" y="1450"><field name="VAR" id="U`@^+}zO-PellA5{w{DV">ducks</field></block><block type="forever" id="#lbRR3h(`7]*%5n^LF$9" x="-1067" y="1645"></block><block type="spritesetpos" id="djOQ.Dv#c5O?q_bIz.E/" disabled-reasons="pxt_automatic_disabled" x="2001" y="1593"><value name="sprite"><block type="variables_get" id="aIb:Ev6T+VL$pW^re3G~" disabled-reasons="pxt_automatic_disabl