ype="argument_reporter_string" id="]Ua_nO^c?[}0ddcjuVTZ"><mutation localizationname="miniMenu.onButtonPressed|handlerParam|selection"></mutation><field name="VALUE">selection</field></block></value><value name="B"><shadow type="text" id="(kMsZ;;HUwr16z|[u{mB"><field name="TEXT">Credits</field></shadow></value></block></value><statement name="DO4"><block type="game_show_long_text" id="w2legq|G!d@6tyevNmE`"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="tt`Q!91wCyShe4@wD4]J"><field name="TEXT">All assets are made by RoboVacDev.</field></shadow></value><next><block type="game_show_long_text" id="9tKqUjj`|gYPR[kzd6jm"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="_,QjOD:G4vhBtpxYT_|L"><field name="TEXT">Intro Animation by Cheetor11.</field></shadow></value></block></next></block></statement><statement name="ELSE"><block type="game_show_long_text" id="C=%/a+%3t9yWa2*5ymU3"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="%)x4Z(*=6QX_~dso,5_a"><field name="TEXT">Ducks are taking over the fields in this fast-paced scrolling shooter game!</field></shadow></value><next><block type="game_show_long_text" id="oN;:T_rAaz;kVVa/4IM#"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="Mv5FA!U)UItTX]YpFnUp"><field name="TEXT">Move up and down to move, and press A to shoot.</field></shadow></value><next><block type="game_show_long_text" id="Q6W^`5N-CgE0SG4(LOET"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="QmCvQ@p5Se[QTU_h6tGt"><field name="TEXT">Shoot the score boosters to get a quick, 5-sec score boost.</field></shadow></value><next><block type="game_show_long_text" id="n|{F[zTt0$:53aZpGDqH"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="d6toIwo-gu[+LzmKDk#^"><field name="TEXT">Also, look out for shield powerups! Shoot those and gain a 10-sec shield boost!</field></shadow></value><next><block type="game_show_long_text" id="9in]/S;|b{#*j)#e0M^2"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="/(QOL7SQ1Mk1NJax{5=N"><field name="TEXT">Shoot the ducks or avoid them. Just don't let them touch YOU!</field></shadow></value><next><block type="game_show_long_text" id="f3Xd%`g4a%gn*01d;P5@"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="QoybDn-%Yn?DcmJCQW({"><field name="TEXT">Things get harder on score 200. Let's hope the start was enough to get you ready!</field></shadow></value><next><block type="game_show_long_text" id="7rB2Kd:t^xq5Ire4{}36"><field name="layout">DialogLayout.Center</field><value name="str"><shadow type="text" id="GcF-DlJvK1T~!?$Pn[/Q"><field name="TEXT">And that's all! Now you know how to play Duck Hunters. Get out there and hunt some ducks!</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></next></block></statement></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="variables_set" id="St4zB!8f6g?)=ig@t3Z1" disabled-reasons="pxt_automatic_disabled" x="1676" y="1361"><field name="VAR" id="U`@^+}zO-PellA5{w{DV">ducks</field><value name="VALUE"><shadow type="math_number" id="Nh`(:bC%Vdm1h4W9z1)f"><field name="NUM">0</field></shadow><block type="spritescreate" id="`-HC?5_r*VkHLjf?uq5T" disabled-reasons="pxt_automatic_disabled"><value name="img"><shadow type="screen_image_picker" id="ETazv;+DhH+A8(V4K-O." disabled-reasons="pxt_automatic_disabled"><field name="img">assets.image`Duck`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image7"}}</data>